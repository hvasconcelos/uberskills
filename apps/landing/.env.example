# uberSKILLS Landing Page — Environment Variables
# Copy this file to .env.local and modify as needed.
# Do NOT commit .env.local to version control.

# Environment mode (development | production).
NODE_ENV=development

# Canonical site URL (used for sitemap, robots, and OpenGraph)
NEXT_PUBLIC_SITE_URL=https://uberskills.dev

# Umami Analytics (optional — omit to disable tracking)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_URL=https://cloud.umami.is/script.js
